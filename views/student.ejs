<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Details</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #e6f0ff;
            margin: 0;
            padding: 0;
        }

        h1 {
            background-color: #004080;
            color: white;
            padding: 20px;
            text-align: center;
            margin: 0;
        }

        .container {
            max-width: 600px;
            margin: 30px auto;
            background-color: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 10px rgba(0, 0, 255, 0.1);
        }

        p {
            font-size: 16px;
            margin: 10px 0;
            color: #003366;
        }

        strong {
            color: #004080;
        }

        .actions {
            margin-top: 20px;
        }

        a {
            text-decoration: none;
            color: white;
            background-color: #0073e6;
            padding: 10px 15px;
            border-radius: 5px;
            margin-right: 10px;
            display: inline-block;
        }

        a:hover {
            background-color: #0059b3;
        }

        button {
            background-color: #cc0000;
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 5px;
            cursor: pointer;
        }

        button:hover {
            background-color: #990000;
        }

        .back-link {
            display: inline-block;
            margin-top: 20px;
            background-color: #004080;
        }

        .back-link:hover {
            background-color: #00264d;
        }
    </style>
</head>

<body>
    <h1>Student Details</h1>

    <div class="container">
        <p><strong>ID:</strong> <%= student._id %></p>
        <p><strong>Name:</strong> <%= student.name %></p>
        <p><strong>Age:</strong> <%= student.age %></p>
        <p><strong>Course:</strong> <%= student.course %></p>

        <div class="actions">
            <a href="/student/<%= student._id %>/edit">Edit</a>

            <form action="/student/<%= student._id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit">Delete</button>
            </form>
        </div>

        <a href="/students" class="back-link">Back to List</a>
    </div>
</body>
</html>
