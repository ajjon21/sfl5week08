<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Students List</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #e6f0ff;
            margin: 0;
            padding: 0;
        }

        h1 {
            background-color: #004080;
            color: white;
            padding: 20px;
            text-align: center;
            margin: 0;
        }

        ul {
            list-style-type: none;
            padding: 0;
            max-width: 600px;
            margin: 30px auto;
        }

        li {
            background-color: #ffffff;
            margin: 10px 0;
            padding: 15px;
            border-left: 5px solid #0073e6;
            border-radius: 5px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        li:hover {
            transform: translateX(5px);
            box-shadow: 0 2px 8px rgba(0, 0, 255, 0.2);
        }

        a {
            text-decoration: none;
            color: #004080;
            font-weight: bold;
        }

        a:hover {
            color: #0073e6;
        }

        .add-link {
            display: block;
            text-align: center;
            margin: 20px auto;
            width: fit-content;
            padding: 10px 20px;
            background-color: #0073e6;
            color: white;
            border-radius: 5px;
            text-decoration: none;
        }

        .add-link:hover {
            background-color: #0059b3;
        }
    </style>
</head>

<body>
    <h1>Students List</h1>
    <ul>
        <% students.forEach(student=> { %>
            <li>
                <a href="/student/<%= student._id %>">
                    <%= student.name %> - <%= student.course %>
                </a>
            </li>
        <% }) %>
    </ul>

    <a href="/student/new" class="add-link">Add a New Student</a>
</body>
</html>
